{
  "expo": {
    "name": "serial3-exposicao-virtual",
    "slug": "serial3-exposicao-virtual",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "serial3exposicaovirtual",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.serial3corporation.serial3exposicaovirtual"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.serial3corporation.serial3exposicaovirtual"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "@reactvision/react-viro",
        {
          "android": {
            "xRMode": "AR"
          },
          "ios": {
            "cameraUsagePermission": "O app precisa da câmera para exibir a exposição virtual em AR.",
            "microphoneUsagePermission": "O app precisa do microfone para interações na exposição.",
            "photosPermission": "O app precisa acessar a galeria para salvar capturas da exposição.",
            "savephotosPermission": "O app precisa de permissão para salvar fotos da experiência AR."
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5666f245-1632-4339-917c-677d5db84883"
      }
    },
    "owner": "serial3-corporation"
  }
}